@model IEnumerable<ProductListItemDto>
@{
    ViewData["Title"] = "Home Page";
}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="mb-3">
                <i class="fas fa-shopping-bag"></i> Ürün Kataloğu
            </h1>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-inbox"></i>
                    <p class="mb-0 mt-2">Ürün bulunamadı</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 shadow-sm border-0">
                        <!-- Resim Bölümü -->
                        <div class="position-relative overflow-hidden" style="aspect-ratio: 1;">
                            @if (!string.IsNullOrEmpty(product.CoverImageUrl))
                            {
                                <img src="@product.CoverImageUrl" alt="@product.Name" class="card-img-top" style="object-fit: cover; width: 100%; height: 100%;">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="width: 100%; height: 100%;">
                                    <i class="fas fa-image text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }

                            @if (product.DiscountRate > 0)
                            {
                                <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                                    -@product.DiscountRate.ToString("F0")%
                                </span>
                            }
                        </div>

                        <!-- İçerik Bölümü -->
                        <div class="card-body d-flex flex-column">
                            <!-- Marka -->
                            <small class="text-muted text-uppercase">
                                @product.BrandName
                            </small>

                            <!-- Kategori ve Alt Kategori -->
                            <div class="mb-2">
                                <span class="badge bg-light text-dark me-1">@product.CategoryName</span>
                                <span class="badge bg-secondary">@product.SubcategoryName</span>
                            </div>

                            <!-- Ürün Adı -->
                            <h6 class="card-title flex-grow-1">@product.Name</h6>

                            <!-- Rating -->
                            <div class="mb-3">
                                <div class="mb-1">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        @if (i < product.Rating)
                                        {
                                            <i class="fas fa-star text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star text-warning"></i>
                                        }
                                    }
                                </div>
                                <small class="text-muted">(@product.ReviewCount değerlendirme)</small>
                            </div>

                            <!-- Fiyat -->
                            <div class="mb-3">
                                <p class="mb-0">
                                    <strong class="text-success fs-5">₺@product.DiscountedPrice.ToString("F2")</strong>
                                    @if (product.DiscountRate > 0)
                                    {
                                        <span class="text-muted text-decoration-line-through ms-2">₺@product.Price.ToString("F2")</span>
                                    }
                                </p>
                            </div>

                            <!-- Sepete Ekle Butonu -->
                            <button class="btn btn-primary w-100" onclick="addToCart(@product.Id)">
                                <i class="fas fa-cart-plus"></i> Sepete Ekle
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    function addToCart(productId) {
        console.log('Ürün ' + productId + ' sepete eklendi');
    }
</script>
