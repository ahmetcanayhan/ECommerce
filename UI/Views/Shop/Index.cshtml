@model CartDto
@{
    ViewData["Title"] = "Alışveriş Sepeti";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evgzccna+0/ffjdhWoihem4LkfH1DxY/Rf3MSDZC3ii2tn2e+1cym8AdTcmdotqFVly006mtUrcFgyeNuid3Q==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8">
            <h1 class="mb-4">Alışveriş Sepeti</h1>

            @if (Model?.Items?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Ürün</th>
                                <th>Fiyat</th>
                                <th>İndirimli Fiyat</th>
                                <th>Miktar</th>
                                <th>Toplam</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="align-middle">
                                    <td>
                                        <div class="d-flex gap-3">
                                            @if (!string.IsNullOrEmpty(item.ProductImage))
                                            {
                                                <img src="@item.ProductImage"
                                                     alt="@item.ProductName"
                                                     class="rounded"
                                                     style="width: 80px; height: 80px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                                     style="width: 80px; height: 80px;">
                                                    <i class="fas fa-image text-muted" style="font-size: 2rem;"></i>
                                                </div>
                                            }
                                            <div>
                                                <h6 class="mb-0">@item.ProductName</h6>
                                                <small class="text-muted">Ürün ID: @item.ProductId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-muted text-decoration-line-through">
                                            @item.Price.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("tr-TR"))
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fw-bold text-success">
                                            @item.DiscountedPrice.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("tr-TR"))
                                        </span>
                                    </td>
                                    <td>
                                        <div class="input-group" style="width: 100px;">
                                            <a class="btn btn-outline-secondary btn-sm" asp-action="addToCart" asp-controller="shop" asp-route-pid="@item.ProductId" asp-route-quantity="-1">−</a>
                                            <input type="number"
                                                   class="form-control form-control-sm text-center"
                                                   value="@item.Quantity"
                                                   min="1"
                                                   readonly>
                                            <a class="btn btn-outline-secondary btn-sm" asp-action="addToCart" asp-controller="shop" asp-route-pid="@item.ProductId">+</a>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="fw-bold">
                                            @((item.DiscountedPrice* item.Quantity).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("tr-TR")))
                                        </span>
                                    </td>
                                    <td>
                                       <a class="btn btn-outline-secondary btn-sm border-0 rounded-circle p-2" asp-action="removeFromCart" asp-controller="shop" asp-route-pid="@item.ProductId">
                                           <i class="fa-solid fa-trash-can text-danger"></i>
                                       </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info d-flex align-items-center" role="alert">
                    <div>
                        <strong>Sepetiniz boş!</strong> Ürün eklemek için alışverişe devam edin.
                    </div>
                </div>
            }
        </div>

        <!-- Özet Kartı -->
        <div class="col-lg-4">
            <div class="card sticky-lg-top">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Sipariş Özeti</h5>
                </div>
                <div class="card-body">
                    @{
                        var totalDiscount = Model?.Items?.Any() == true
                        ? Model.Items.Sum(i => (i.Price - i.DiscountedPrice) * i.Quantity)
                        : 0m;
                    }

                    @if (Model?.Items?.Any() == true)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>Ara Toplam:</span>
                            <span>
                                @Model.Items.Sum(i => i.DiscountedPrice * i.Quantity).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("tr-TR"))
                            </span>
                        </div>

                        @if (totalDiscount > 0)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>İndirim:</span>
                                <span>-@totalDiscount.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("tr-TR"))</span>
                            </div>
                        }

                        <div class="d-flex justify-content-between mb-2">
                            <span>Kargo:</span>
                            <span>
                                <small class="text-muted">Ücretsiz</small>
                            </span>
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between mb-3">
                            <strong>Toplam:</strong>
                            <strong class="text-success">
                                @Model.Items.Sum(i => i.DiscountedPrice * i.Quantity).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("tr-TR"))
                            </strong>
                        </div>
                        <form asp-action="create" asp-controller="order" method="post">
                        <button class="btn btn-success w-100 mb-2" type="submit"> 
                            Ödemeye Geç
                        </button>
                        </form>
                        <button class="btn btn-outline-secondary w-100" type="button">
                            Alışverişe Devam Et
                        </button>
                    }
                    else
                    {
                        <p class="text-muted text-center">Sepete ürün ekleyin</p>
                        <button class="btn btn-primary w-100" type="button">
                            Alışverişe Başla
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Özet İstatistikleri -->
    @if (Model?.Items?.Any() == true)
    {
        <div class="row mt-5">
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-title text-muted">Toplam Ürün</h6>
                        <h3 class="mb-0">@Model.Items.Sum(i => i.Quantity)</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-title text-muted">Çeşit Sayısı</h6>
                        <h3 class="mb-0">@Model.Items.Count()</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-title text-muted">Toplam İndirim</h6>
                        <h3 class="mb-0 text-success">@Model.Items.Sum(i => (i.Price - i.DiscountedPrice) * i.Quantity).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("tr-TR"))</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-title text-muted">Müşteri ID</h6>
                        <small class="text-muted">@Model.CustomerId</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 0, 0, 0.02);
    }

    .sticky-lg-top {
        position: sticky;
        top: 20px;
    }

    img {
        transition: transform 0.3s ease;
    }

    .table-responsive img:hover {
        transform: scale(1.05);
    }

    .card {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        transition: box-shadow 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }

    .btn-outline-danger {
        font-size: 1.2rem;
        padding: 0.25rem 0.5rem;
    }

    .input-group {
        border-radius: 0.25rem;
    }

    .form-control-sm {
        font-size: 0.875rem;
    }
</style>
